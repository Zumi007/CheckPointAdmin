@page "/tesztek"
@using CheckPointAdmin.Models
@using System.Xml.Linq
@inject Supabase.Client Db
@inject IJSRuntime JSRuntime

<PageTitle>Tesztek Kezelése</PageTitle>

<div class="row mb-4">
    <div class="col">
        <h1><i class="bi bi-file-earmark-arrow-up text-primary me-2"></i>Tesztek Kezelése</h1>
        <p class="text-muted">Kezeld manuálisan tesztjeidet, vagy hasznáid az AI Segédet és az importálást.</p>
    </div>
</div>

<!-- NAVIGÁCIÓS FÜLEK -->
<ul class="nav nav-tabs mb-4 border-secondary">
    <li class="nav-item">
        <button class="nav-link @(aktivTab == "lista" ? "active bg-dark text-primary border-secondary border-bottom-0" : "text-secondary")" @onclick='() => aktivTab = "lista"'>
            <i class="bi bi-list-task me-2"></i>Tesztek listája
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(aktivTab == "import" ? "active bg-dark text-primary border-secondary border-bottom-0" : "text-secondary")" @onclick='() => aktivTab = "import"'>
            <i class="bi bi-filetype-xml me-2"></i>XML Importálás & AI Segéd
        </button>
    </li>
</ul>

@if (aktivTab == "import")
{
    <div class="row g-4">
        <!-- AI PROMPT GENERÁTOR -->
        <div class="col-lg-6">
            <div class="card bg-dark border-primary h-100 shadow">
                <div class="card-body">
                    <h5 class="text-primary mb-3"><i class="bi bi-robot me-2"></i>AI Prompt Segéd</h5>
                    <p class="small text-muted mb-4">Állítsd be a paramétereket és másold a promptot az AI-ba.</p>

                    <div class="mb-3">
                        <label class="form-label small">Teszt témája</label>
                        <input type="text" class="form-control" placeholder="pl. KRESZ szabályok..." @bind="promptTema" @bind:event="oninput" />
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small">Kérdések</label>
                            <input type="number" class="form-control" min="1" max="50" @bind="promptKerdesSzam" @bind:event="oninput" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Válaszok / kérdés</label>
                            <input type="number" class="form-control" min="2" max="6" @bind="promptValaszSzam" @bind:event="oninput" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Nehézségi szint</label>
                            <select class="form-select" @bind="promptNehezseg">
                                <option value="Kezdő">Kezdő</option>
                                <option value="Középhaladó">Középhaladó</option>
                                <option value="Haladó">Haladó</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-info">Generált utasítás (Prompt):</label>
                        <textarea class="form-control bg-black text-info border-info x-small" rows="8" readonly value="@GeneralatPrompt"></textarea>
                    </div>

                    <button class="btn btn-outline-primary w-100" @onclick="MasolasVagolapra">
                        <i class="bi bi-clipboard me-2"></i>Prompt másolása
                    </button>

                    @if (masolva)
                    {
                        <div class="text-success small mt-2 text-center animate-fade">Másolva a vágólapra!</div>
                    }
                </div>
            </div>
        </div>

        <!-- XML FELTÖLTÉS -->
        <div class="col-lg-6">
            <div class="card bg-dark border-secondary h-100 shadow-sm">
                <div class="card-body text-center d-flex flex-column justify-content-center py-5">
                    <h5 class="text-light mb-3"><i class="bi bi-upload me-2"></i>XML Fájl Importálása</h5>
                    <div class="d-flex justify-content-center mb-4">
                        <InputFile OnChange="HandleFileSelected" class="form-control w-75 bg-dark text-light border-secondary" accept=".xml" />
                    </div>
                    @if (isImporting)
                    {
                        <div class="my-3"><div class="spinner-border text-primary mb-2"></div><p class="text-info small">@importStatusz</p></div>
                    }
                    @if (!string.IsNullOrEmpty(hibaUzenet))
                    {
                        <div class="alert alert-danger mt-4 small">@hibaUzenet</div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- MANUÁLIS HOZZÁADÁS -->
    <div class="card bg-dark border-secondary mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title text-light mb-3">Új teszt alapadatai</h5>
            <div class="row g-2">
                <div class="col-md-4"><input type="text" class="form-control" placeholder="Teszt címe" @bind="ujTesztCime" /></div>
                <div class="col-md-6"><input type="text" class="form-control" placeholder="Leírás" @bind="ujLeiras" /></div>
                <div class="col-md-2">
                    <button class="btn btn-success w-100" @onclick="TesztHozzaadas" disabled="@string.IsNullOrWhiteSpace(ujTesztCime)">
                        <i class="bi bi-plus-circle me-1"></i> Létrehozás
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (tesztek == null)
    {
        <div class="text-center my-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (!tesztek.Any())
    {
        <div class="alert alert-info bg-transparent border-info text-info text-center p-4">Nincsenek tesztek rögzítve.</div>
    }
    else
    {
        <div class="table-responsive rounded shadow-sm">
            <table class="table table-dark table-striped table-hover mb-0 border-secondary">
                <thead>
                    <tr>
                        <th style="width: 50px;"></th>
                        <th>Teszt címe / Leírás</th>
                        <th style="width: 100px;">Állapot</th>
                        <th style="width: 300px;" class="text-end">Műveletek</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in tesztek)
                    {
                        <tr class="align-middle">
                            <td>
                                <button class="btn btn-sm btn-outline-info" @onclick="() => ToggleKeresek(t.TesztId)">
                                    <i class="bi @(nyitottTesztek.Contains(t.TesztId) ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                </button>
                            </td>
                            <td>
                                <div class="fw-bold">@t.TesztCime</div>
                                <small class="text-muted text-truncate d-block" style="max-width: 400px;">@t.Leiras</small>
                            </td>
                            <td>
                                <span class="badge @(t.Aktiv ? "bg-success" : "bg-danger")">@(t.Aktiv ? "Aktív" : "Inaktív")</span>
                            </td>
                            <td class="text-end">
                                @if (torlesAlattId == t.TesztId)
                                {
                                    <span class="text-danger small me-2">Biztosan törlöd?</span>
                                    <button class="btn btn-sm btn-danger me-1" @onclick="() => VeglegesTorles(t.TesztId)">Igen</button>
                                    <button class="btn btn-sm btn-outline-light" @onclick="() => torlesAlattId = null">Nem</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-primary me-1" title="Szerkesztés"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm @(t.Aktiv ? "btn-outline-warning" : "btn-outline-info") me-1" @onclick="() => TesztAllapot(t)">
                                        <i class="bi @(t.Aktiv ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => torlesAlattId = t.TesztId" title="Törlés">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>

                        @if (nyitottTesztek.Contains(t.TesztId))
                        {
                            <tr class="bg-black bg-opacity-25">
                                <td colspan="4" class="p-4 border-start border-info border-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="text-info mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>Kérdések</h6>
                                        <div class="input-group input-group-sm w-50">
                                            <input type="text" class="form-control" placeholder="Új kérdés..." @bind="ujKerdesSzoveg" />
                                            <button class="btn btn-info px-3" @onclick="() => KerdesHozzaadas(t.TesztId)"><i class="bi bi-plus-lg"></i></button>
                                        </div>
                                    </div>
                                    @if (kerdesek != null)
                                    {
                                        @foreach (var k in kerdesek.Where(k => k.TesztId == t.TesztId))
                                        {
                                            <div class="card bg-dark border-secondary mb-2 shadow-sm">
                                                <div class="card-body p-2 d-flex justify-content-between align-items-center">
                                                    <span><strong class="text-info me-2">K:</strong> @k.KerdesSzoveg</span>
                                                    <div>
                                                        <button class="btn btn-sm btn-link text-info p-0 me-3 text-decoration-none" @onclick="() => ToggleValaszok(k.KerdesId)">
                                                            Válaszok (@(valaszok?.Count(v => v.KerdesId == k.KerdesId) ?? 0))
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger border-0" @onclick="() => KerdesTorles(k.KerdesId)"><i class="bi bi-trash"></i></button>
                                                    </div>
                                                </div>
                                                @if (nyitottKerdesek.Contains(k.KerdesId) && valaszok != null)
                                                {
                                                    <div class="card-footer bg-black bg-opacity-10 border-top border-secondary">
                                                        @foreach (var v in valaszok.Where(v => v.KerdesId == k.KerdesId))
                                                        {
                                                            <div class="small py-1 border-bottom border-secondary border-opacity-10 d-flex justify-content-between">
                                                                <span><i class="bi @(v.Helyes ? "bi-check-circle-fill text-success" : "bi-circle text-muted") me-2"></i>@v.ValaszSzoveg</span>
                                                                <button class="btn btn-sm btn-link text-danger p-0 ms-2" @onclick="() => ValaszTorles(v.ValaszId)"><i class="bi bi-x"></i></button>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private List<Teszt>? tesztek;
    private List<Kerdes>? kerdesek;
    private List<Valasz>? valaszok;
    private HashSet<long> nyitottTesztek = new();
    private HashSet<long> nyitottKerdesek = new();
    private string hibaUzenet = "";
    private string aktivTab = "lista";
    private long? torlesAlattId = null;

    private string promptTema = "";
    private int promptKerdesSzam = 10;
    private int promptValaszSzam = 4;
    private string promptNehezseg = "Kezdő";
    private bool masolva = false;

    private string GeneralatPrompt =>
        $"Készíts egy XML fájlt egy teszthez:\n- Téma: {(!string.IsNullOrEmpty(promptTema) ? promptTema : "[TÉMA]")}\n" +
        $"- Nehézségi szint: {promptNehezseg}\n" +
        $"- Kérdések: {promptKerdesSzam}\n- Válaszok: {promptValaszSzam}\n\n" +
        $"Az AI-tól elvárt, hogy a kérdések és válaszok nyelvezete és bonyolultsága feleljen meg a(z) {promptNehezseg} szintnek.\n\n" +
        "Struktúra:\n" +
        "<Teszt cim=\"...\" leiras=\"...\"><Kerdesek><Kerdes szoveg=\"...\"><Valaszok>" +
        "<Valasz helyes=\"true\">...</Valasz></Valaszok></Kerdes></Kerdesek></Teszt>";

    private bool isImporting = false;
    private string importStatusz = "";
    private string ujTesztCime = "", ujLeiras = "";
    private string ujKerdesSzoveg = "";

    protected override async Task OnInitializedAsync() => await Betoltes();

    private async Task Betoltes()
    {
        try
        {
            var tResp = await Db.From<Teszt>().Order("Teszt_id", Supabase.Postgrest.Constants.Ordering.Ascending).Get();
            tesztek = tResp.Models;
            var kResp = await Db.From<Kerdes>().Get();
            kerdesek = kResp.Models;
            var vResp = await Db.From<Valasz>().Get();
            valaszok = vResp.Models;
        }
        catch (Exception ex) { Console.WriteLine(ex); }
    }

    private async Task MasolasVagolapra()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", GeneralatPrompt);
        masolva = true; StateHasChanged();
        await Task.Delay(3000); masolva = false; StateHasChanged();
    }

    private async Task VeglegesTorles(long id)
    {
        try
        {
            hibaUzenet = "";
            var kerdesIds = kerdesek?.Where(k => k.TesztId == id).Select(k => k.KerdesId).ToList();

            if (kerdesIds != null && kerdesIds.Any())
            {
                foreach (var kId in kerdesIds)
                {
                    await Db.From<Valasz>().Where(v => v.KerdesId == kId).Delete();
                }
                await Db.From<Kerdes>().Where(k => k.TesztId == id).Delete();
            }

            await Db.From<Teszt>().Where(x => x.TesztId == id).Delete();
            torlesAlattId = null;
            await Betoltes();
        }
        catch (Exception ex)
        {
            hibaUzenet = "Hiba a törléskor: " + ex.Message;
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        hibaUzenet = ""; isImporting = true; importStatusz = "Feldolgozás...";
        try
        {
            using var stream = e.File.OpenReadStream();
            var doc = await XDocument.LoadAsync(stream, LoadOptions.None, default);
            var tesztElem = doc.Element("Teszt");
            var ujTeszt = new Teszt
            {
                TesztCime = tesztElem.Attribute("cim")?.Value ?? "Importált",
                Leiras = tesztElem.Attribute("leiras")?.Value ?? "",
                Aktiv = true
            };
            var resp = await Db.From<Teszt>().Insert(ujTeszt);
            var tid = resp.Model.TesztId;
            foreach (var ke in tesztElem.Element("Kerdesek")?.Elements("Kerdes") ?? Enumerable.Empty<XElement>())
            {
                var rk = await Db.From<Kerdes>().Insert(new Kerdes { TesztId = tid, KerdesSzoveg = ke.Attribute("szoveg")?.Value });
                foreach (var ve in ke.Element("Valaszok")?.Elements("Valasz") ?? Enumerable.Empty<XElement>())
                {
                    await Db.From<Valasz>().Insert(new Valasz
                    {
                        KerdesId = rk.Model.KerdesId,
                        ValaszSzoveg = ve.Value,
                        Helyes = bool.TryParse(ve.Attribute("helyes")?.Value, out var h) && h
                    });
                }
            }
            aktivTab = "lista"; await Betoltes();
        }
        catch (Exception ex) { hibaUzenet = "Import hiba: " + ex.Message; }
        finally { isImporting = false; }
    }

    private void ToggleKeresek(long id) { if (nyitottTesztek.Contains(id)) nyitottTesztek.Remove(id); else nyitottTesztek.Add(id); }
    private void ToggleValaszok(long id) { if (nyitottKerdesek.Contains(id)) nyitottKerdesek.Remove(id); else nyitottKerdesek.Add(id); }
    private async Task TesztHozzaadas()
    {
        await Db.From<Teszt>().Insert(new Teszt { TesztCime = ujTesztCime, Leiras = ujLeiras, Aktiv = true });
        ujTesztCime = ""; ujLeiras = ""; await Betoltes();
    }
    private async Task TesztAllapot(Teszt t) { t.Aktiv = !t.Aktiv; await Db.From<Teszt>().Update(t); await Betoltes(); }
    private async Task KerdesHozzaadas(long tid) { await Db.From<Kerdes>().Insert(new Kerdes { TesztId = tid, KerdesSzoveg = ujKerdesSzoveg }); ujKerdesSzoveg = ""; await Betoltes(); }
    private async Task KerdesTorles(long id)
    {
        await Db.From<Valasz>().Where(x => x.KerdesId == id).Delete();
        await Db.From<Kerdes>().Where(x => x.KerdesId == id).Delete();
        await Betoltes();
    }
    private async Task ValaszTorles(long id) { await Db.From<Valasz>().Where(x => x.ValaszId == id).Delete(); await Betoltes(); }
}