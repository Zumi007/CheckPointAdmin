@page "/kiosztasok"
@using CheckPointAdmin.Models
@inject Supabase.Client Db

<PageTitle>Tesztek Kiosztása</PageTitle>

<div class="row mb-4 align-items-center">
    <div class="col">
        <h1><i class="bi bi-send-check text-primary me-2"></i>Tesztek Kiosztása</h1>
        <p class="text-muted">Rendelj teszteket a csoportokhoz, és állítsd be a vizsga paramétereit.</p>
    </div>
</div>

<!-- ÚJ KIOSZTÁS LÉTREHOZÁSA -->
<div class="card bg-dark border-secondary mb-4 shadow-sm">
    <div class="card-body">
        <h5 class="card-title text-light mb-3">Új kiosztás rögzítése</h5>
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label small text-muted">Teszt kiválasztása</label>
                <select class="form-select bg-dark text-light border-secondary" @bind="ujTesztId">
                    <option value="0">-- Válassz tesztet --</option>
                    @if (tesztek != null)
                    {
                        @foreach (var t in tesztek.Where(x => x.Aktiv))
                        {
                            <option value="@t.TesztId">@t.TesztCime</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted">Célcsoport</label>
                <select class="form-select bg-dark text-light border-secondary" @bind="ujCsoportId">
                    <option value="0">-- Válassz csoportot --</option>
                    @if (csoportok != null)
                    {
                        @foreach (var cs in csoportok.Where(x => x.Aktiv))
                        {
                            <option value="@cs.CsoportId">@cs.CsoportNev</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-muted">Határidő (opcionális)</label>
                <input type="datetime-local" class="form-control bg-dark text-light border-secondary" @bind="ujHatarido" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-success w-100 fw-bold" @onclick="KiosztasMentese" disabled="@(ujTesztId == 0 || ujCsoportId == 0)">
                    <i class="bi bi-plus-lg me-1"></i> Kiosztás rögzítése
                </button>
            </div>

            <!-- VÉLETLENSZERŰSÉG ÉS LÁTHATÓSÁG BEÁLLÍTÁSOK -->
            <div class="col-12 mt-2">
                <div class="d-flex flex-wrap gap-4 p-2 bg-black bg-opacity-25 rounded border border-secondary border-opacity-25">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="qRand" @bind="ujKerdesekVeletlen">
                        <label class="form-check-label small text-muted" for="qRand">Véletlen kérdés sorrend</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="aRand" @bind="ujValaszokVeletlen">
                        <label class="form-check-label small text-muted" for="aRand">Véletlen válasz sorrend</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="vShow" @bind="ujVegeredmenyLathato">
                        <label class="form-check-label small text-muted" for="vShow">Végelemzés megengedve</label>
                    </div>
                </div>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(hibaUzenet))
        {
            <div class="alert alert-danger mt-3 mb-0">@hibaUzenet</div>
        }
    </div>
</div>

<!-- KIOSZTÁSOK LISTÁJA -->
@if (kiosztasok == null)
{
    <div class="text-center my-5"><div class="spinner-border text-primary"></div></div>
}
else if (!kiosztasok.Any())
{
    <div class="alert alert-info bg-transparent border-info text-info text-center p-4">
        Még nem történt egyetlen tesztkiosztás sem.
    </div>
}
else
{
    <div class="table-responsive rounded shadow-sm">
        <table class="table table-dark table-striped table-hover mb-0 border-secondary">
            <thead>
                <tr>
                    <th>Teszt / Létrehozva</th>
                    <th>Csoport</th>
                    <th class="text-center">Beállítások</th>
                    <th>Határidő</th>
                    <th style="width: 250px;" class="text-end">Műveletek</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var k in kiosztasok)
                {
                    var teszt = tesztek?.FirstOrDefault(x => x.TesztId == k.TesztId);
                    var csoport = csoportok?.FirstOrDefault(x => x.CsoportId == k.CsoportId);

                    <tr class="align-middle">
                        <td>
                            @if (szerkesztettId == k.KiosztasId)
                            {
                                <select class="form-select form-select-sm bg-dark text-light border-secondary" @bind="szerkesztettTesztId">
                                    @foreach (var t in tesztek!.Where(x => x.Aktiv || x.TesztId == k.TesztId))
                                    {
                                        <option value="@t.TesztId">@t.TesztCime</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <div class="fw-bold text-info">@(teszt?.TesztCime ?? "Ismeretlen teszt")</div>
                                <small class="text-muted">@k.Letrehozva.ToString("yyyy.MM.dd. HH:mm")</small>
                            }
                        </td>
                        <td>
                            @if (szerkesztettId == k.KiosztasId)
                            {
                                <select class="form-select form-select-sm bg-dark text-light border-secondary" @bind="szerkesztettCsoportId">
                                    @foreach (var cs in csoportok!.Where(x => x.Aktiv || x.CsoportId == k.CsoportId))
                                    {
                                        <option value="@cs.CsoportId">@cs.CsoportNev</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@(csoport?.CsoportNev ?? "Ismeretlen")</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (szerkesztettId == k.KiosztasId)
                            {
                                <div class="d-flex flex-column gap-1 align-items-center">
                                    <div class="form-check form-switch small" title="Kérdéskeverés">
                                        <input class="form-check-input" type="checkbox" @bind="szerkesztettKerdesekVeletlen">
                                        <i class="bi bi-shuffle text-success ms-1"></i>
                                    </div>
                                    <div class="form-check form-switch small" title="Válaszkeverés">
                                        <input class="form-check-input" type="checkbox" @bind="szerkesztettValaszokVeletlen">
                                        <i class="bi bi-shuffle text-info ms-1"></i>
                                    </div>
                                    <div class="form-check form-switch small" title="Eredményelemzés">
                                        <input class="form-check-input" type="checkbox" @bind="szerkesztettVegeredmenyLathato">
                                        <i class="bi bi-eye-fill text-warning ms-1"></i>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex justify-content-center gap-2">
                                    <i class="bi @(k.KerdesekVeletlen ? "bi-shuffle text-success" : "bi-list-ol text-muted")" title="Kérdéskeverés"></i>
                                    <i class="bi @(k.ValaszokVeletlen ? "bi-shuffle text-info" : "bi-list-ul text-muted")" title="Válaszkeverés"></i>
                                    <i class="bi @(k.VegeredmenyLathato ? "bi-eye-fill text-warning" : "bi-eye-slash text-muted")" title="Eredményelemzés"></i>
                                </div>
                            }
                        </td>
                        <td>
                            @if (szerkesztettId == k.KiosztasId)
                            {
                                <input type="datetime-local" class="form-control form-control-sm bg-dark text-light border-secondary" @bind="szerkesztettHatarido" />
                            }
                            else
                            {
                                @if (k.Hatarido.HasValue)
                                {
                                    <span class="@(k.Hatarido < DateTime.Now ? "text-danger" : "text-light") small">
                                        <i class="bi bi-calendar-event me-1"></i>@k.Hatarido.Value.ToString("yyyy.MM.dd. HH:mm")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">Nincs megadva</span>
                                }
                            }
                        </td>
                        <td class="text-end">
                            @if (szerkesztettId == k.KiosztasId)
                            {
                                <button class="btn btn-sm btn-success me-1" @onclick="() => Mentes(k)">
                                    <i class="bi bi-save me-1"></i> Mentés
                                </button>
                                <button class="btn btn-sm btn-outline-light" @onclick="Megse">
                                    Mégse
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Szerkesztes(k)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm @(k.Aktiv ? "btn-outline-warning" : "btn-outline-success") me-1" @onclick="() => AllapotValtas(k)" title="@(k.Aktiv ? "Szüneteltetés" : "Aktiválás")">
                                    <i class="bi @(k.Aktiv ? "bi-pause-fill" : "bi-play-fill")"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Torles(k.KiosztasId)" title="Törlés">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Kiosztas>? kiosztasok;
    private List<Teszt>? tesztek;
    private List<Csoport>? csoportok;

    // Új kiosztás változók
    private long ujTesztId = 0;
    private long ujCsoportId = 0;
    private DateTime? ujHatarido;
    private bool ujKerdesekVeletlen = false;
    private bool ujValaszokVeletlen = false;
    private bool ujVegeredmenyLathato = false;

    private string hibaUzenet = "";

    // Szerkesztési állapot változók
    private long? szerkesztettId = null;
    private long szerkesztettTesztId;
    private long szerkesztettCsoportId;
    private DateTime? szerkesztettHatarido;
    private bool szerkesztettKerdesekVeletlen;
    private bool szerkesztettValaszokVeletlen;
    private bool szerkesztettVegeredmenyLathato;

    protected override async Task OnInitializedAsync() => await Betoltes();

    private async Task Betoltes()
    {
        try
        {
            var tTask = Db.From<Teszt>().Get();
            var cTask = Db.From<Csoport>().Get();
            var kTask = Db.From<Kiosztas>().Order("Letrehozva", Supabase.Postgrest.Constants.Ordering.Descending).Get();

            await Task.WhenAll(tTask, cTask, kTask);

            tesztek = tTask.Result.Models;
            csoportok = cTask.Result.Models;
            kiosztasok = kTask.Result.Models;
        }
        catch (Exception ex) { hibaUzenet = "Hiba az adatok szinkronizálásakor: " + ex.Message; }
    }

    private async Task KiosztasMentese()
    {
        try
        {
            var uj = new Kiosztas
            {
                TesztId = ujTesztId,
                CsoportId = ujCsoportId,
                Hatarido = ujHatarido,
                KerdesekVeletlen = ujKerdesekVeletlen,
                ValaszokVeletlen = ujValaszokVeletlen,
                VegeredmenyLathato = ujVegeredmenyLathato,
                Aktiv = true
            };

            await Db.From<Kiosztas>().Insert(uj);

            // Alaphelyzet
            ujTesztId = 0; ujCsoportId = 0; ujHatarido = null;
            ujKerdesekVeletlen = false; ujValaszokVeletlen = false; ujVegeredmenyLathato = false;

            await Betoltes();
        }
        catch (Exception ex) { hibaUzenet = "Hiba a mentés során: " + ex.Message; }
    }

    private void Szerkesztes(Kiosztas k)
    {
        szerkesztettId = k.KiosztasId;
        szerkesztettTesztId = k.TesztId;
        szerkesztettCsoportId = k.CsoportId;
        szerkesztettHatarido = k.Hatarido;
        szerkesztettKerdesekVeletlen = k.KerdesekVeletlen;
        szerkesztettValaszokVeletlen = k.ValaszokVeletlen;
        szerkesztettVegeredmenyLathato = k.VegeredmenyLathato;
    }

    private void Megse()
    {
        szerkesztettId = null;
    }

    private async Task Mentes(Kiosztas k)
    {
        try
        {
            k.TesztId = szerkesztettTesztId;
            k.CsoportId = szerkesztettCsoportId;
            k.Hatarido = szerkesztettHatarido;
            k.KerdesekVeletlen = szerkesztettKerdesekVeletlen;
            k.ValaszokVeletlen = szerkesztettValaszokVeletlen;
            k.VegeredmenyLathato = szerkesztettVegeredmenyLathato;

            await Db.From<Kiosztas>().Update(k);
            szerkesztettId = null;
            await Betoltes();
        }
        catch (Exception ex) { hibaUzenet = "Hiba a módosításkor: " + ex.Message; }
    }

    private async Task AllapotValtas(Kiosztas k)
    {
        try
        {
            k.Aktiv = !k.Aktiv;
            await Db.From<Kiosztas>().Update(k);
            await Betoltes();
        }
        catch (Exception ex) { hibaUzenet = "Hiba az állapot módosításakor: " + ex.Message; }
    }

    private async Task Torles(long id)
    {
        try
        {
            await Db.From<Kiosztas>().Where(x => x.KiosztasId == id).Delete();
            await Betoltes();
        }
        catch (Exception ex) { hibaUzenet = "Hiba a törléskor: " + ex.Message; }
    }
}